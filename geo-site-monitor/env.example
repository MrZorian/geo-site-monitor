# Flask Configuration
SECRET_KEY=your-secret-key-change-this-in-production
DATABASE_URL=sqlite:///monitor.db

# Target Website
TARGET_URL=https://your-website.com

# Proxy Configuration (comma separated)
# Format: http://ip:port or http://user:pass@ip:port
PROXY_LIST=http://proxy1:8080,http://user:pass@proxy2:8080

# Session Settings
SESSIONS_PER_DAY=35
MIN_SESSION_DURATION=240
MAX_SESSION_DURATION=300
PAGES_PER_SESSION=4

# Browser Settings
HEADLESS=true
USER_AGENT_ROTATION=true

# Railway will set this automatically
PORT=5000